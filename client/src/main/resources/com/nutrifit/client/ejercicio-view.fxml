<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.nutrifit.client.controller.EjercicioController"
            style="-fx-background-color: linear-gradient(to right, #0f172a, #111827);">

    <top>
        <VBox spacing="10"
              style="-fx-background-color: linear-gradient(to right, #111827, #1f2937); -fx-padding: 18;">
            <Label text="NutriFit"
                   style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
            <Label text="Registro de ejercicios"
                   style="-fx-text-fill: #cbd5e1; -fx-font-size: 14px;"/>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.45">
            <items>

                <!-- Izquierda: selector de fecha + tabla de registros del día -->
                <VBox spacing="12"
                      style="-fx-background-color: #0f172a; -fx-padding: 16;">

                    <Label text="Fecha"
                           style="-fx-text-fill: #e5e7eb; -fx-font-size: 13px;"/>

                    <HBox spacing="8">
                        <DatePicker fx:id="fechaPicker"
                                    HBox.hgrow="ALWAYS"
                                    onAction="#onCargarFecha"/>
                        <Button text="Cargar"
                                onAction="#onCargarFecha"
                                style="-fx-background-color: #334155; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 8 14;"/>
                    </HBox>

                    <Label text="Ejercicios del día"
                           style="-fx-text-fill: #e5e7eb; -fx-font-size: 13px;"/>

                    <TableView fx:id="registrosTable"
                               VBox.vgrow="ALWAYS"
                               style="-fx-background-radius: 12;">
                        <columns>
                            <TableColumn fx:id="colEjercicio" text="Ejercicio" prefWidth="180"/>
                            <TableColumn fx:id="colDuracion" text="Min" prefWidth="60"/>
                            <TableColumn fx:id="colKcal" text="Kcal quemadas" prefWidth="120"/>
                        </columns>
                    </TableView>

                    <HBox spacing="8">
                        <Button fx:id="eliminarButton"
                                text="Eliminar registro"
                                onAction="#onEliminar"
                                disable="true"
                                style="-fx-background-color: #dc2626; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 8 14;"/>
                        <Button text="Volver"
                                onAction="#onVolver"
                                style="-fx-background-color: #475569; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 8 14;"/>
                    </HBox>

                </VBox>

                <!-- Derecha: formulario para registrar ejercicio -->
                <VBox spacing="12"
                      style="-fx-background-color: #111827; -fx-padding: 16;">

                    <Label text="Registrar ejercicio"
                           style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>

                    <Label text="Ejercicio"
                           style="-fx-text-fill: #e5e7eb; -fx-font-size: 13px;"/>

                    <ComboBox fx:id="ejercicioComboBox"
                              maxWidth="Infinity"/>

                    <Label text="Duración (minutos)"
                           style="-fx-text-fill: #e5e7eb; -fx-font-size: 13px;"/>

                    <HBox spacing="8">
                        <TextField fx:id="duracionField"
                                   promptText="30"
                                   prefWidth="100"
                                   style="-fx-background-radius: 10; -fx-padding: 8; -fx-font-size: 13px;"/>
                        <Button fx:id="registrarButton"
                                text="Registrar"
                                onAction="#onRegistrar"
                                style="-fx-background-color: #16a34a; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 8 14;"/>
                    </HBox>

                </VBox>

            </items>
        </SplitPane>
    </center>

    <bottom>
        <Label fx:id="statusLabel"
               text="Listo"
               maxWidth="Infinity"
               style="-fx-background-color: #020617; -fx-text-fill: #93c5fd; -fx-padding: 12; -fx-font-size: 13px;"/>
    </bottom>

</BorderPane>
