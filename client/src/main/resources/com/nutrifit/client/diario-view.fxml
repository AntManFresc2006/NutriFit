<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.nutrifit.client.controller.DiarioController"
            style="-fx-background-color: linear-gradient(to right, #0f172a, #111827);">

    <top>
        <VBox spacing="4" style="-fx-padding: 20 20 10 20;">
            <Label text="NutriFit"
                   style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;"/>
            <Label text="Resumen diario nutricional"
                   style="-fx-text-fill: #cbd5e1; -fx-font-size: 14px;"/>
        </VBox>
    </top>

    <center>
        <HBox spacing="24" style="-fx-padding: 0 20 20 20;">

            <!-- Columna izquierda: controles + métricas -->
            <VBox spacing="16" minWidth="420">

                <HBox spacing="12">
                    <DatePicker fx:id="fechaPicker"/>
                    <Button text="Recargar"
                            onAction="#onRecargar"
                            style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 10 16;"/>
                    <Button text="Volver"
                            onAction="#onVolver"
                            style="-fx-background-color: #475569; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 10 16;"/>
                </HBox>

                <GridPane hgap="24" vgap="14">
                    <padding><Insets top="6" right="6" bottom="6" left="6"/></padding>

                    <Label text="Kcal consumidas"
                           style="-fx-text-fill: #e5e7eb; -fx-font-size: 15px;"
                           GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <Label fx:id="kcalLabel" text="0 kcal"
                           style="-fx-text-fill: #86efac; -fx-font-size: 17px; -fx-font-weight: bold;"
                           GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Proteínas"
                           style="-fx-text-fill: #e5e7eb; -fx-font-size: 15px;"
                           GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <Label fx:id="proteinasLabel" text="0 g"
                           style="-fx-text-fill: #93c5fd; -fx-font-size: 17px; -fx-font-weight: bold;"
                           GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Grasas"
                           style="-fx-text-fill: #e5e7eb; -fx-font-size: 15px;"
                           GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <Label fx:id="grasasLabel" text="0 g"
                           style="-fx-text-fill: #f9a8d4; -fx-font-size: 17px; -fx-font-weight: bold;"
                           GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                    <Label text="Carbohidratos"
                           style="-fx-text-fill: #e5e7eb; -fx-font-size: 15px;"
                           GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <Label fx:id="carbosLabel" text="0 g"
                           style="-fx-text-fill: #fcd34d; -fx-font-size: 17px; -fx-font-weight: bold;"
                           GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                    <Label text="Kcal quemadas"
                           style="-fx-text-fill: #e5e7eb; -fx-font-size: 15px;"
                           GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <Label fx:id="kcalQuemadasLabel" text="0 kcal"
                           style="-fx-text-fill: #fb923c; -fx-font-size: 17px; -fx-font-weight: bold;"
                           GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                    <Label text="TDEE (mantenimiento)"
                           style="-fx-text-fill: #e5e7eb; -fx-font-size: 15px;"
                           GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                    <Label fx:id="tdeeLabel" text="0 kcal"
                           style="-fx-text-fill: #67e8f9; -fx-font-size: 17px; -fx-font-weight: bold;"
                           GridPane.rowIndex="5" GridPane.columnIndex="1"/>

                    <Label text="Balance real"
                           style="-fx-text-fill: #e5e7eb; -fx-font-size: 15px;"
                           GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                    <Label fx:id="balanceRealLabel" text="0 kcal"
                           style="-fx-text-fill: #94a3b8; -fx-font-size: 17px; -fx-font-weight: bold;"
                           GridPane.rowIndex="6" GridPane.columnIndex="1"/>

                    <Label text="Estado"
                           style="-fx-text-fill: #e5e7eb; -fx-font-size: 15px;"
                           GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                    <Label fx:id="estadoBalanceLabel" text="—"
                           style="-fx-text-fill: #94a3b8; -fx-font-size: 17px; -fx-font-weight: bold;"
                           GridPane.rowIndex="7" GridPane.columnIndex="1"/>
                </GridPane>
            </VBox>

            <!-- Columna derecha: evaluación IA -->
            <VBox spacing="12" HBox.hgrow="ALWAYS">
                <Label text="Evaluación IA"
                       style="-fx-text-fill: #cbd5e1; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                <TextArea fx:id="iaTextArea"
                          editable="false"
                          wrapText="true"
                          promptText="Pulsa 'Evaluar con IA' para obtener un análisis personalizado de tu día."
                          VBox.vgrow="ALWAYS"
                          style="-fx-background-color: #1e293b; -fx-text-fill: #e2e8f0; -fx-font-size: 13px; -fx-border-color: #334155; -fx-border-radius: 8; -fx-background-radius: 8; -fx-control-inner-background: #1e293b;"/>
                <Button text="Evaluar con IA"
                        onAction="#onEvaluarConIa"
                        maxWidth="Infinity"
                        style="-fx-background-color: #7c3aed; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 10 16; -fx-font-size: 14px;"/>
            </VBox>

        </HBox>
    </center>

    <bottom>
        <Label fx:id="statusLabel"
               text="Cargando resumen..."
               maxWidth="Infinity"
               style="-fx-background-color: #020617; -fx-text-fill: #93c5fd; -fx-padding: 12; -fx-font-size: 13px;"/>
    </bottom>
</BorderPane>
