<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.nutrifit.client.controller.FoodController">

    <top>
        <VBox spacing="10" style="-fx-background-color: linear-gradient(to right, #111827, #1f2937); -fx-padding: 18;">
            <Label text="NutriFit"
                   style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
            <Label text="Gestión de alimentos"
                   style="-fx-text-fill: #cbd5e1; -fx-font-size: 14px;"/>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.62">
            <items>

                <VBox spacing="12" style="-fx-background-color: #0f172a; -fx-padding: 16;">
                    <HBox spacing="10">
                        <TextField fx:id="searchField"
                                   promptText="Buscar alimento..."
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-background-radius: 10; -fx-padding: 10; -fx-font-size: 14px;"/>
                        <Button text="Buscar"
                                onAction="#onBuscar"
                                style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 10 16;"/>
                        <Button text="Recargar"
                                onAction="#onRecargar"
                                style="-fx-background-color: #334155; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 10 16;"/>
                    </HBox>

                    <TableView fx:id="foodTable" VBox.vgrow="ALWAYS" style="-fx-background-radius: 12;">
                        <columns>
                            <TableColumn fx:id="idColumn" text="ID" prefWidth="60"/>
                            <TableColumn fx:id="nombreColumn" text="Nombre" prefWidth="220"/>
                            <TableColumn fx:id="porcionColumn" text="Porción (g)" prefWidth="110"/>
                            <TableColumn fx:id="kcalColumn" text="Kcal/100g" prefWidth="110"/>
                            <TableColumn fx:id="proteinasColumn" text="Proteínas" prefWidth="100"/>
                            <TableColumn fx:id="grasasColumn" text="Grasas" prefWidth="90"/>
                            <TableColumn fx:id="carbosColumn" text="Carbos" prefWidth="90"/>
                            <TableColumn fx:id="fuenteColumn" text="Fuente" prefWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>

                <VBox spacing="14" style="-fx-background-color: #111827; -fx-padding: 18;">
                    <Label text="Formulario de alimento"
                           style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>

                    <GridPane hgap="10" vgap="12">
                        <padding>
                            <Insets top="4" right="4" bottom="4" left="4"/>
                        </padding>

                        <Label text="Nombre" style="-fx-text-fill: #e5e7eb;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="nombreField"
                                   promptText="Ej. Pollo a la plancha"
                                   GridPane.rowIndex="0"
                                   GridPane.columnIndex="1"/>

                        <Label text="Porción (g)" style="-fx-text-fill: #e5e7eb;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="porcionField"
                                   promptText="100"
                                   GridPane.rowIndex="1"
                                   GridPane.columnIndex="1"/>

                        <Label text="Kcal/100g" style="-fx-text-fill: #e5e7eb;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <TextField fx:id="kcalField"
                                   promptText="165"
                                   GridPane.rowIndex="2"
                                   GridPane.columnIndex="1"/>

                        <Label text="Proteínas" style="-fx-text-fill: #e5e7eb;" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <TextField fx:id="proteinasField"
                                   promptText="31.0"
                                   GridPane.rowIndex="3"
                                   GridPane.columnIndex="1"/>

                        <Label text="Grasas" style="-fx-text-fill: #e5e7eb;" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                        <TextField fx:id="grasasField"
                                   promptText="3.6"
                                   GridPane.rowIndex="4"
                                   GridPane.columnIndex="1"/>

                        <Label text="Carbos" style="-fx-text-fill: #e5e7eb;" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                        <TextField fx:id="carbosField"
                                   promptText="0.0"
                                   GridPane.rowIndex="5"
                                   GridPane.columnIndex="1"/>

                        <Label text="Fuente" style="-fx-text-fill: #e5e7eb;" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                        <TextField fx:id="fuenteField"
                                   promptText="manual"
                                   GridPane.rowIndex="6"
                                   GridPane.columnIndex="1"/>
                    </GridPane>

                    <HBox spacing="10">
                        <Button text="Nuevo"
                                onAction="#onNuevo"
                                style="-fx-background-color: #475569; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 10 16;"/>
                        <Button text="Guardar"
                                onAction="#onGuardar"
                                style="-fx-background-color: #16a34a; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 10 16;"/>
                        <Button text="Eliminar"
                                onAction="#onEliminar"
                                style="-fx-background-color: #dc2626; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 10 16;"/>
                    </HBox>
                </VBox>

            </items>
        </SplitPane>
    </center>

    <bottom>
        <Label fx:id="statusLabel"
               text="Estado"
               style="-fx-background-color: #020617; -fx-text-fill: #93c5fd; -fx-padding: 12; -fx-font-size: 13px;"/>
    </bottom>
</BorderPane>