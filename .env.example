# Plantilla de variables de entorno para NutriFit.
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas el .env al repositorio.

# Base de datos MariaDB
MARIADB_ROOT_PASSWORD=cambia_esto
MARIADB_PASSWORD=cambia_esto

# API Keys de OpenRouter (https://openrouter.ai)
# Necesitas una clave por modelo o puedes usar la misma para los dos.
OPENROUTER_API_KEY=sk-or-v1-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# URL del backend en producción (usada por el cliente en el instalador)
BACKEND_PRODUCTION_URL=https://api.nutrifit.tudominio.com
